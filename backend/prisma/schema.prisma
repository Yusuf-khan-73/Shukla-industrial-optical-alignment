generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                   @id @default(autoincrement())
  email                 String                @unique @db.VarChar(255)
  hashed_password       String                @db.VarChar(255)
  full_name             String                @default("Admin") @db.VarChar(255)
  is_active             Boolean               @default(true)
  is_superuser          Boolean               @default(true)
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  password_reset_tokens PasswordResetToken[]

  @@index([email], map: "ix_users_email")
  @@map("users")
}

model Project {
  id                Int            @id @default(autoincrement())
  title             String         @db.VarChar(255)
  slug              String         @unique @db.VarChar(255)
  client            String         @db.VarChar(255)
  location          String         @db.VarChar(255)
  industry          String         @db.VarChar(100)
  industry_label    String         @db.VarChar(255)
  completion_date   DateTime?      @db.Date
  service_type      String         @db.VarChar(255)
  short_description String         @default("")
  description       String         @default("")
  featured          Boolean        @default(false)
  is_active         Boolean        @default(true)
  sort_order        Int            @default(0)
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  images            ProjectImage[]

  @@index([industry], map: "ix_projects_industry")
  @@index([slug], map: "ix_projects_slug")
  @@map("projects")
}

model ProjectImage {
  id         Int     @id @default(autoincrement())
  project_id Int
  image_url  String  @db.VarChar(500)
  alt_text   String  @default("") @db.VarChar(255)
  sort_order Int     @default(0)
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([project_id], map: "ix_project_images_project_id")
  @@map("project_images")
}

model Gallery {
  id             Int            @id @default(autoincrement())
  title          String         @db.VarChar(255)
  company        String         @db.VarChar(255)
  location       String         @db.VarChar(255)
  date           String?        @db.VarChar(50)
  category       String         @default("general") @db.VarChar(100)
  category_label String         @default("General") @db.VarChar(100)
  description    String         @default("")
  featured       Boolean        @default(false)
  is_active      Boolean        @default(true)
  sort_order     Int            @default(0)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  updated_at     DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  images         GalleryImage[]

  @@map("gallery")
}

model GalleryImage {
  id         Int     @id @default(autoincrement())
  gallery_id Int
  image_url  String  @db.VarChar(500)
  alt_text   String  @default("") @db.VarChar(255)
  sort_order Int     @default(0)
  gallery    Gallery @relation(fields: [gallery_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([gallery_id], map: "ix_gallery_images_gallery_id")
  @@map("gallery_images")
}

model Client {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(255)
  initials       String   @default("") @db.VarChar(10)
  category       String   @db.VarChar(100)
  category_label String   @db.VarChar(100)
  logo_url       String?  @db.VarChar(500)
  website        String?  @db.VarChar(500)
  featured       Boolean  @default(false)
  is_active      Boolean  @default(true)
  sort_order     Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([category], map: "ix_clients_category")
  @@map("clients")
}

model Service {
  id                Int            @id @default(autoincrement())
  title             String         @db.VarChar(255)
  slug              String         @unique @db.VarChar(255)
  short_description String         @default("")
  description       String         @default("")
  icon              String         @default("bi-gear") @db.VarChar(100)
  benefits          Json?          @default("[]")
  faqs              Json?          @default("[]")
  image_url         String?        @db.VarChar(500)
  is_active         Boolean        @default(true)
  sort_order        Int            @default(0)
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  images            ServiceImage[]

  @@index([slug], map: "ix_services_slug")
  @@map("services")
}

model ServiceImage {
  id         Int     @id @default(autoincrement())
  service_id Int
  image_url  String  @db.VarChar(500)
  alt_text   String  @default("") @db.VarChar(255)
  sort_order Int     @default(0)
  service    Service @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([service_id], map: "ix_service_images_service_id")
  @@map("service_images")
}

model Testimonial {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  designation String   @default("") @db.VarChar(255)
  company     String   @db.VarChar(255)
  quote       String
  rating      Int      @default(5)
  initials    String   @default("") @db.VarChar(10)
  featured    Boolean  @default(false)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("testimonials")
}

model HeroSlide {
  id         Int      @id @default(autoincrement())
  image_url  String   @db.VarChar(500)
  alt_text   String   @default("") @db.VarChar(255)
  caption    String?  @db.VarChar(500)
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("hero_slides")
}

model ContactMessage {
  id                  Int      @id @default(autoincrement())
  name                String   @db.VarChar(255)
  phone               String   @db.VarChar(50)
  email               String   @db.VarChar(255)
  company_name        String   @default("") @db.VarChar(255)
  city                String   @default("") @db.VarChar(255)
  service_required    String   @default("") @db.VarChar(255)
  message             String
  is_read             Boolean  @default(false)
  inquiry_number      String?  @unique(map: "ix_contact_messages_inquiry_number") @db.VarChar(50)
  admin_email_sent    Boolean  @default(false)
  customer_email_sent Boolean  @default(false)
  email_error         String?
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "ix_contact_messages_created_at")
  @@index([is_read], map: "ix_contact_messages_is_read")
  @@map("contact_messages")
}

model CompanyInformation {
  id                Int      @id @default(autoincrement())
  company_name      String   @db.VarChar(255)
  tagline           String   @default("") @db.VarChar(255)
  description       String   @default("")
  logo              String?  @default("") @db.VarChar(500)
  phone_1           String?  @default("") @db.VarChar(30)
  phone_2           String?  @default("") @db.VarChar(30)
  phones            Json?    @default("[]")
  email             String   @default("") @db.VarChar(255)
  admin_login_email String   @unique @db.VarChar(255)
  whatsapp_number   String?  @default("") @db.VarChar(20)
  office_address    String?  @default("")
  google_map_url    String?  @default("") @db.VarChar(1000)
  facebook          String?  @default("") @db.VarChar(500)
  instagram         String?  @default("") @db.VarChar(500)
  linkedin          String?  @default("") @db.VarChar(500)
  youtube           String?  @default("") @db.VarChar(500)
  address           Json?    @default("{}")
  working_hours     Json?    @default("{}")
  stats             Json?    @default("[]")
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("company_information")
}

model SiteSettings {
  id            Int      @id @default(autoincrement())
  map_embed_url String   @default("") @db.VarChar(1000)
  social_links  Json?    @default("{}")
  seo_defaults  Json?    @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("site_settings")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  email      String    @db.VarChar(255)
  token_hash String    @unique @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  used       Boolean   @default(false)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([email], map: "ix_password_reset_tokens_email")
  @@index([token_hash], map: "ix_password_reset_tokens_token_hash")
  @@index([user_id], map: "ix_password_reset_tokens_user_id")
  @@map("password_reset_tokens")
}
