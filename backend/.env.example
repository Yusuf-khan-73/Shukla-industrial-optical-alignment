# Shukla Industrial — Backend Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Application
APP_NAME=Shukla Industrial Optical Alignment API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server (frontend defaults to http://localhost:8001 in DEV)
HOST=0.0.0.0
PORT=8001

# Database — Supabase PostgreSQL
# Production MUST use Transaction pooler (:6543), NOT db.*.supabase.co:5432
# Required query params prevent Postgres 42P05 with PgBouncer / Prisma
DATABASE_URL=postgresql://postgres.jrekzxylpmnaqmhxfdox:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require

# JWT Authentication — CHANGE IN PRODUCTION
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Uploads
# On Vercel Serverless, uploads are written under /tmp automatically (ephemeral).
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Admin (initial seed ONLY)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe@123

# Frontend URL (password reset links)
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_EXPIRE_MINUTES=15
PASSWORD_RESET_PATH=/reset-password
ADMIN_DASHBOARD_PATH=/admin

# Company branding (emails)
COMPANY_NAME=SHUKLA INDUSTRIAL OPTICAL ALIGNMENT
COMPANY_PHONE=+91 9510900608
COMPANY_EMAIL=sioaw98@yahoo.com
COMPANY_WEBSITE=www.shuklaalignment.com

# SMTP — Gmail example (use a Google App Password, never your account password)
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=your-gmail@gmail.com
SMTP_FROM_NAME=Shukla Industrial Optical Alignment
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
