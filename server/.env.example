# Shukla Industrial — Backend Environment Variables
# Copy to .env and adjust for your environment

# Application
APP_NAME=Shukla Industrial Optical Alignment API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL — install locally)
DATABASE_URL=postgresql://shukla_user:shukla_pass@localhost:5432/shukla_industrial

# JWT Authentication — CHANGE IN PRODUCTION
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated origins — must include your frontend URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Admin (initial seed ONLY — after first startup, change login email in Company Settings)
# ADMIN_EMAIL is used once to create the default company.admin_login_email + users.email.
# Runtime login/forgot-password always use company_information.admin_login_email in PostgreSQL.
ADMIN_EMAIL=yusufmohmmad7300@gmail.com
ADMIN_PASSWORD=ChangeMe@123

# Frontend URL (password reset links)
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_EXPIRE_MINUTES=15
PASSWORD_RESET_PATH=/reset-password

# Company branding (used in password reset emails)
COMPANY_NAME=SHUKLA INDUSTRIAL OPTICAL ALIGNMENT
COMPANY_PHONE=+91 9510900608
COMPANY_EMAIL=sioaw98@yahoo.com
COMPANY_WEBSITE=www.shuklaalignment.com

# SMTP (for password reset emails)
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_TLS=true
# Use an app password for SMTP_PASSWORD when using Gmail.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_USE_TLS=true
