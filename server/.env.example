# Shukla Industrial — Backend Environment Variables
# Copy to .env and adjust for your environment

# Application
APP_NAME=Shukla Industrial Optical Alignment API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL — install locally)
DATABASE_URL=postgresql://shukla_user:shukla_pass@localhost:5432/shukla_industrial

# JWT Authentication — CHANGE IN PRODUCTION
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated origins — must include your frontend URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Admin (initial seed — change after first login)
ADMIN_EMAIL=admin@shuklaindustrial.com
ADMIN_PASSWORD=ChangeMe@123
