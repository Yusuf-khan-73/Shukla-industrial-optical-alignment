# Shukla Industrial — Frontend Environment Variables
# Copy to .env for local development

# Absolute API base (recommended for production / separate Vercel projects)
# Local: leave as /api/v1 and set VITE_API_ORIGIN, OR set full URL
VITE_API_BASE_URL=/api/v1

# Backend origin — used for /uploads image URLs and (in DEV) to build API base if BASE_URL is relative
VITE_API_ORIGIN=http://localhost:8001

# Public site URL (SEO)
VITE_SITE_URL=http://localhost:5173

# Google Maps embed URL (editable via Admin Panel)
VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7521.4!2d72.9261012!3d20.3787777!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be0ce4b2fd124cb%3A0xff6c5955d1b4310d!2sSushanti%20Housing%20Society!5e0!3m2!1sen!2sin!4v1

# --- Production (Vercel) example ---
# VITE_API_BASE_URL=https://shukla-industrial-backend.vercel.app/api/v1
# VITE_API_ORIGIN=https://shukla-industrial-backend.vercel.app
# VITE_SITE_URL=https://shukla-industrial-frontend.vercel.app
