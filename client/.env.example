# Shukla Industrial — Frontend Environment Variables
# Copy to .env and adjust for your environment

# API — in dev, axios uses VITE_API_ORIGIN + /api/v1 (direct to Express on :8001)
# For production behind same host, set VITE_API_BASE_URL=/api/v1
VITE_API_BASE_URL=/api/v1

# Backend origin — required for dev API calls
VITE_API_ORIGIN=http://localhost:8001

# Public site URL (used for SEO)
VITE_SITE_URL=http://localhost:5173

# Google Maps embed URL (editable via Admin Panel)
VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d7521.4!2d72.9261012!3d20.3787777!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be0ce4b2fd124cb%3A0xff6c5955d1b4310d!2sSushanti%20Housing%20Society!5e0!3m2!1sen!2sin!4v1
